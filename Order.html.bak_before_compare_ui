<script>
    // ---- 使用者コード・卓番 ----
    // 使用者コードは「従業員登録」画面で登録済みのコードから選択する方式（自由入力は廃止）
    let staffCode = localStorage.getItem('staffCode') || '';
    let tableNumber = localStorage.getItem('staffTableNumber') || '';

    document.getElementById('table-number-input').value = tableNumber;

    function onStaffInfoChange() {
        staffCode = document.getElementById('staff-code-input').value.trim();
        tableNumber = document.getElementById('table-number-input').value.trim();
        localStorage.setItem('staffCode', staffCode);
        localStorage.setItem('staffTableNumber', tableNumber);
        updateTableChips();
    }

    function updateTableChips() {
        const label = tableNumber ? `テーブル ${tableNumber}` : 'テーブル —';
        document.querySelectorAll('#table-chip, #table-chip2').forEach(el => {
            el.textContent = label;
        });
        document.getElementById('cart-staff-info').textContent =
            `使用者コード: ${staffCode || '—'} / 卓番: ${tableNumber || '—'}`;
        document.getElementById('home-sub').textContent =
            `使用者コード: ${staffCode || '—'} / 卓番: ${tableNumber || '—'}`;
    }
    updateTableChips();

    let currentQty = 1;
    let modalCode = null;
    let cart = [];
    let currentCategory = 'all';
    let searchKeyword = '';

    // ---- メニューデータ（Firestore「CookList」コレクションから取得） ----
    let menuData = {};
    let menuList = [];

    // カテゴリ判定（メニュー番号の先頭から推定）
    function getCategory(code) {
        code = String(code);
        if (code.startsWith("1")) return "appetizer";
        if (code.startsWith("21")) return "doria";
        if (code.startsWith("22")) return "pizza";
        if (code.startsWith("23")) return "pasta";
        if (code.startsWith("24")) return "meat";
        if (code.startsWith("31")) return "rice";
        if (code.startsWith("32")) return "dessert";
        if (code.startsWith("5")) return "drink";
        return "other";
    }
    const categoryMeta = {
        all:       { label: "すべて",       icon: "🍽" },
        appetizer: { label: "前菜・サラダ", icon: "🥗" },
        doria:     { label: "ドリア",       icon: "🍚" },
        pizza:     { label: "ピザ",         icon: "🍕" },
        pasta:     { label: "パスタ",       icon: "🍝" },
        meat:      { label: "肉・グリル",   icon: "🥩" },
        rice:      { label: "ライス・パン", icon: "🍞" },
        dessert:   { label: "デザート",     icon: "🍰" },
        drink:     { label: "ドリンク",     icon: "🥤" },
        other:     { label: "その他",       icon: "🍴" },
    };

    // 在庫切れ判定（品切れフラグまたは残数0）
    function isOutOfStock(item) {
        if (item.soldOut) return true;
        if (item.stockQty !== null && item.stockQty !== undefined && item.stockQty <= 0) return true;
        return false;
    }

    // ---- FirestoreのCookListコレクションからメニューを取得 ----
    async function loadMenuFromFirestore() {
        const snapshot = await window.fbGetDocs(
            window.fbCollection(window.db, 'CookList')
        );
        const list = [];
        snapshot.forEach(docSnap => {
            const data = docSnap.data() || {};
            const code = String(data.code ?? docSnap.id);
            const category = getCategory(code);
            const stockQty = (data.stockQty === null || data.stockQty === undefined || data.stockQty === '') ? null : Number(data.stockQty);
            list.push({
                docId: docSnap.id,
                code,
                name: data.name || data.shortName || '(名称未設定)',
                price: Number(data.price) || 0,
                category,
                icon: categoryMeta[category]?.icon || '🍴',
                soldOut: !!data.soldOut,
                stockQty: stockQty,
                allergens: Array.isArray(data.allergens) ? data.allergens : []
            });
        });
        list.sort((a, b) => a.code.localeCompare(b.code));
        menuList = list;
        menuData = {};
        list.forEach(item => { menuData[item.code] = item; });
    }

    // ---- カテゴリタブ描画 ----
    function renderCategoryTabs() {
        const usedCats = ['all', ...new Set(menuList.map(m => m.category))];
        const wrap = document.getElementById('category-tabs');
        wrap.innerHTML = usedCats.map(cat => `
            <button class="cat-tab${cat === currentCategory ? ' active' : ''}" onclick="selectCategory('${cat}')">
                ${categoryMeta[cat].icon} ${categoryMeta[cat].label}
            </button>
        `).join('');
    }

    function selectCategory(cat) {
        currentCategory = cat;
        renderCategoryTabs();
        renderMenuGrid();
        document.getElementById('menu-scroll').scrollTop = 0;
    }

    function onSearchInput() {
        searchKeyword = document.getElementById('search-input').value.trim();
        renderMenuGrid();
    }

    // ---- メニューグリッド描画 ----
    function renderMenuGrid() {
        let items = menuList;
        if (currentCategory !== 'all') items = items.filter(m => m.category === currentCategory);
        if (searchKeyword) items = items.filter(m => m.name.includes(searchKeyword) || m.code.includes(searchKeyword));

        const grid = document.getElementById('menu-grid');
        if (menuList.length === 0) {
            grid.innerHTML = `<div class="empty-result"><div style="font-size:40px;margin-bottom:8px;">📭</div>メニューが登録されていません<br><span style="font-size:12px;">(Firestoreの CookList コレクションをご確認ください)</span></div>`;
            return;
        }
        if (items.length === 0) {
            grid.innerHTML = `<div class="empty-result"><div style="font-size:40px;margin-bottom:8px;">🔍</div>該当するメニューが見つかりません</div>`;
            return;
        }
        grid.innerHTML = items.map(item => {
            const inCartQty = cart.filter(c => c.code === item.code).reduce((s, c) => s + c.qty, 0);
            const outOfStock = isOutOfStock(item);
            const lowStock = !outOfStock && item.stockQty !== null && item.stockQty <= 5;
            const hasAllergen = item.allergens && item.allergens.length > 0;
            return `
            <div class="menu-card${outOfStock ? ' sold-out' : ''}" onclick="${outOfStock ? `showToast('⚠️ ${item.name} は品切れ中です')` : `openQtyModal('${item.code}')`}">
                ${inCartQty > 0 && !outOfStock ? `<div class="in-cart-dot" style="display:flex;align-items:center;">×${inCartQty}</div>` : ''}
                ${outOfStock ? `<div class="sold-out-badge">品切れ</div>` : (lowStock ? `<div class="low-stock-badge">残${item.stockQty}点</div>` : '')}
                ${hasAllergen ? `<div class="allergen-badge" title="${item.allergens.join(',')}"><i class="fa-solid fa-triangle-exclamation"></i></div>` : ''}
                <div class="menu-icon">${item.icon}</div>
                <div class="menu-name">${item.name}</div>
                <div class="menu-bottom">
                    <div class="menu-price">${item.price}円</div>
                    <div class="qty-btn" style="width:2rem;height:2rem;font-size:1.1rem;${outOfStock ? 'opacity:.3;' : ''}">+</div>
                </div>
            </div>`;
        }).join('');
    }

    // ---- 数量選択モーダル ----
    function openQtyModal(code) {
        const item = menuData[code];
        if (!item || isOutOfStock(item)) {
            showToast('⚠️ この商品は品切れ中です');
            return;
        }
        modalCode = code;
        currentQty = 1;
        document.getElementById('modal-item-name').textContent = item.name;
        document.getElementById('modal-item-price').textContent = item.price + '円';
        document.getElementById('modal-qty-display').textContent = currentQty;
        document.getElementById('qty-overlay').classList.add('show');
    }
    function closeQtyModal() {
        document.getElementById('qty-overlay').classList.remove('show');
        modalCode = null;
    }
    function changeModalQty(diff) {
        currentQty = Math.max(1, currentQty + diff);
        document.getElementById('modal-qty-display').textContent = currentQty;
    }
    function confirmAddToCart() {
        const item = menuData[modalCode];
        if (!item || isOutOfStock(item)) {
            showToast('⚠️ この商品は品切れ中です');
            closeQtyModal();
            renderMenuGrid();
            return;
        }
        const existing = cart.find(c => c.code === modalCode);
        if (existing) {
            existing.qty += currentQty;
        } else {
            cart.push({ code: modalCode, name: item.name, price: item.price, qty: currentQty });
        }
        updateCartBadge();
        renderMenuGrid();
        showToast(`${item.icon} ${item.name} を${currentQty}点 追加しました`);
        closeQtyModal();
    }

    // ---- カートバッジ ----
    function updateCartBadge() {
        const badge = document.getElementById('cart-badge');
        const totalCount = cart.reduce((s, c) => s + c.qty, 0);
        if (totalCount > 0) {
            badge.textContent = totalCount;
            badge.classList.remove('hidden');
        } else {
            badge.classList.add('hidden');
        }
    }

    // ---- ホーム画面 ページ送り ----
    function showHomePage(n) {
        document.getElementById('home-page-1').classList.toggle('active', n === 1);
        document.getElementById('home-page-2').classList.toggle('active', n === 2);
        document.getElementById('home-dot-1').classList.toggle('active', n === 1);
        document.getElementById('home-dot-2').classList.toggle('active', n === 2);
    }
    // 左右スワイプでもページ送り
    (function initSwipe() {
        const body = document.getElementById('view-home');
        let startX = null;
        body.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive: true });
        body.addEventListener('touchend', e => {
            if (startX === null) return;
            const diff = e.changedTouches[0].clientX - startX;
            if (Math.abs(diff) > 60) {
                showHomePage(diff < 0 ? 2 : 1);
            }
            startX = null;
        }, { passive: true });
    })();

    // ---- 画面切り替え ----
    const FOOTER_PAGES = ['view-menu', 'view-cart'];
    function showPage(pageId) {
        document.querySelectorAll('.page').forEach(p => p.classList.add('hidden'));
        document.getElementById(pageId).classList.remove('hidden');

        const footer = document.getElementById('footer-nav');
        if (FOOTER_PAGES.includes(pageId)) {
            footer.classList.remove('hidden');
        } else {
            footer.classList.add('hidden');
        }

        document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
        if (pageId === 'view-menu') document.getElementById('nav-add').classList.add('active');
        if (pageId === 'view-cart') {
            document.getElementById('nav-cart').classList.add('active');
            renderCart();
        }
        if (pageId === 'view-stock') renderStockList();
        if (pageId === 'view-allergy') renderAllergyList();
        if (pageId === 'view-staff') loadStaffList();
        if (pageId === 'view-tablemove') resetTableMoveUI();
        if (pageId === 'view-merge') resetMergeUI();
    }

    // ---- カート画面描画 ----
    function renderCart() {
        updateTableChips();
        const list = document.getElementById('cart-items-list');
        if (cart.length === 0) {
            list.innerHTML = `<div class="text-center text-gray-400 mt-16">
                <div style="font-size:44px;margin-bottom:10px;">🛒</div>
                注文かごは空です
            </div>`;
            document.getElementById('submit-btn').disabled = true;
        } else {
            document.getElementById('submit-btn').disabled = false;
            list.innerHTML = cart.map((item, index) => {
                const icon = menuData[item.code]?.icon || '🍽';
                return `
                <div class="cart-row">
                    <div class="ci-icon">${icon}</div>
                    <div class="ci-info">
                        <div class="ci-name">${item.name}</div>
                        <div class="ci-sub">${item.price * item.qty}円</div>
                    </div>
                    <div class="qty-ctrl">
                        <button class="qty-btn" onclick="updateCartQty(${index}, -1)">−</button>
                        <div style="min-width:20px;text-align:center;font-weight:900;">${item.qty}</div>
                        <button class="qty-btn" onclick="updateCartQty(${index}, 1)">＋</button>
                    </div>
                </div>`;
            }).join('');
        }
        let totalP = 0, totalC = 0;
        cart.forEach(item => { totalP += item.price * item.qty; totalC += item.qty; });
        document.getElementById('total-count').textContent = totalC + '点';
        document.getElementById('total-price').textContent = `合計 ${totalP}円 (税込)`;
    }

    function updateCartQty(index, diff) {
        cart[index].qty += diff;
        if (cart[index].qty <= 0) cart.splice(index, 1);
        updateCartBadge();
        renderCart();
        renderMenuGrid();
    }

    // ---- 注文送信 ----
    // orderMethod には「使用者コード」の値をそのまま入れる（index.htmlの'SELF'とは異なる区分）
    async function submitOrder() {
        if (cart.length === 0) {
            showToast('注文かごが空です');
            return;
        }
        if (!staffCode) {
            showToast('⚠️ 使用者コードを選択してください');
            showPage('view-menu');
            document.getElementById('staff-code-input').focus();
            return;
        }
        if (!tableNumber) {
            showToast('⚠️ 卓番を入力してください');
            showPage('view-menu');
            document.getElementById('table-number-input').focus();
            return;
        }
        const btn = document.getElementById('submit-btn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> 送信中...';
        try {
            await window.fbAddDoc(
                window.fbCollection(window.db, 'orders'),
                {
                    table: tableNumber,
                    status: 'waiting',
                    orderMethod: staffCode,
                    createdAt: window.fbServerTimestamp(),
                    items: cart
                }
            );
            cart = [];
            updateCartBadge();
            renderMenuGrid();
            showToast(`🎉 ${tableNumber}卓への注文を送信しました！`);
            showPage('view-menu');
        } catch (error) {
            console.error(error);
            showToast('⚠️ 送信に失敗しました。もう一度お試しください。');
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> 注文する';
        }
    }

    // =====================================================================
    // 在庫管理
    // =====================================================================
    let stockEditState = {}; // docId -> {soldOut, stockQty}

    function renderStockList() {
        const kw = (document.getElementById('stock-search-input')?.value || '').trim();
        let items = menuList;
        if (kw) items = items.filter(m => m.name.includes(kw) || m.code.includes(kw));

        const card = document.getElementById('stock-list-card');
        if (items.length === 0) {
            card.innerHTML = `<div class="empty-note">該当する商品がありません</div>`;
            return;
        }
        card.innerHTML = items.map(item => {
            if (!(item.docId in stockEditState)) {
                stockEditState[item.docId] = { soldOut: item.soldOut, stockQty: item.stockQty };
            }
            const st = stockEditState[item.docId];
            return `
            <div class="stock-row">
                <div class="stock-name">${item.name} <span class="code">#${item.code}</span></div>
                <input type="number" class="stock-qty-input" placeholder="残数" value="${st.stockQty === null ? '' : st.stockQty}"
                    onchange="updateStockEditQty('${item.docId}', this.value)">
                <button class="soldout-toggle${st.soldOut ? ' on' : ''}" onclick="toggleStockSoldOut('${item.docId}')">
                    ${st.soldOut ? '品切れ中' : '在庫あり'}
                </button>
            </div>`;
        }).join('');
    }

    function updateStockEditQty(docId, val) {
        const n = val === '' ? null : Number(val);
        stockEditState[docId].stockQty = n;
    }
    function toggleStockSoldOut(docId) {
        stockEditState[docId].soldOut = !stockEditState[docId].soldOut;
        renderStockList();
    }

    async function saveAllStock() {
        const ids = Object.keys(stockEditState);
        if (ids.length === 0) {
            showToast('変更がありません');
            return;
        }
        showToast('保存中...');
        try {
            for (const docId of ids) {
                const st = stockEditState[docId];
                await window.fbUpdateDoc(
                    window.fbDoc(window.db, 'CookList', docId),
                    { soldOut: !!st.soldOut, stockQty: (st.stockQty === null || st.stockQty === undefined) ? null : Number(st.stockQty) }
                );
            }
            await loadMenuFromFirestore();
            stockEditState = {};
            renderStockList();
            renderMenuGrid();
            showToast('✅ 在庫情報を保存しました');
        } catch (e) {
            console.error(e);
            showToast('⚠️ 保存に失敗しました');
        }
    }

    // =====================================================================
    // テーブル変更
    // =====================================================================
    let tmTickets = [];
    let tmSelectedIds = new Set();

    function resetTableMoveUI() {
        document.getElementById('tm-from-table').value = tableNumber || '';
        document.getElementById('tm-tickets-wrap').innerHTML = '';
        document.getElementById('tm-move-card').classList.add('hidden');
        document.getElementById('tm-preview').innerHTML = '';
        document.getElementById('tm-to-table').value = '';
        tmTickets = [];
        tmSelectedIds = new Set();
    }

    async function searchTableMoveTickets() {
        const t = document.getElementById('tm-from-table').value.trim();
        if (!t) { showToast('⚠️ 現在の卓番を入力してください'); return; }
        const wrap = document.getElementById('tm-tickets-wrap');
        wrap.innerHTML = `<div class="empty-note"><i class="fa-solid fa-spinner fa-spin"></i> 検索中...</div>`;
        try {
            const q = window.fbQuery(
                window.fbCollection(window.db, 'orders'),
                window.fbWhere('table', '==', t)
            );
            const snap = await window.fbGetDocs(q);
            tmTickets = [];
            snap.forEach(d => tmTickets.push({ id: d.id, ...d.data() }));
            tmTickets.sort((a, b) => (b.createdAt?.toMillis?.() || 0) - (a.createdAt?.toMillis?.() || 0));
            tmSelectedIds = new Set();
            renderTableMoveTickets();
        } catch (e) {
            console.error(e);
            wrap.innerHTML = `<div class="empty-note">検索に失敗しました</div>`;
        }
    }

    function renderTableMoveTickets() {
        const wrap = document.getElementById('tm-tickets-wrap');
        if (tmTickets.length === 0) {
            wrap.innerHTML = `<div class="empty-note">この卓の伝票は見つかりませんでした</div>`;
            document.getElementById('tm-move-card').classList.add('hidden');
            return;
        }
        wrap.innerHTML = tmTickets.map(t => ticketCardHtml(
            t, tmSelectedIds.has(t.id), `toggleTmSelect('${t.id}')`,
            tmSelectedIds.has(t.id) ? `<div class="move-select-badge"><i class="fa-solid fa-right-left"></i> 移動対象</div>` : ''
        )).join('');
        document.getElementById('tm-move-card').classList.toggle('hidden', tmSelectedIds.size === 0);
        updateTableMovePreview();
    }

    function toggleTmSelect(id) {
        if (tmSelectedIds.has(id)) tmSelectedIds.delete(id); else tmSelectedIds.add(id);
        renderTableMoveTickets();
    }

    function updateTableMovePreview() {
        const from = document.getElementById('tm-from-table').value.trim() || '—';
        const toInput = document.getElementById('tm-to-table');
        const to = toInput ? (toInput.value.trim() || '未入力') : '未入力';
        const preview = document.getElementById('tm-preview');
        if (!preview) return;
        if (tmSelectedIds.size === 0) { preview.innerHTML = ''; return; }
        preview.innerHTML = `
            <div class="tm-box from">変更前<br>${from}卓 (${tmSelectedIds.size}枚)</div>
            <div class="tm-arrow"><i class="fa-solid fa-arrow-right-long"></i></div>
            <div class="tm-box to">変更後<br>${to}${to !== '未入力' ? '卓' : ''}</div>`;
    }

    async function executeTableMove() {
        const to = document.getElementById('tm-to-table').value.trim();
        if (!to) { showToast('⚠️ 移動先の卓番を入力してください'); return; }
        if (tmSelectedIds.size === 0) { showToast('⚠️ 移動する伝票を選択してください'); return; }
        const from = document.getElementById('tm-from-table').value.trim() || '—';
        if (!confirm(`【変更前】${from}卓 → 【変更後】${to}卓\n選択した${tmSelectedIds.size}枚の伝票を移動します。よろしいですか？`)) return;
        try {
            for (const id of tmSelectedIds) {
                await window.fbUpdateDoc(window.fbDoc(window.db, 'orders', id), { table: to });
            }
            showToast(`✅ ${from}卓 → ${to}卓 へ ${tmSelectedIds.size}枚の伝票を移動しました`);
            resetTableMoveUI();
        } catch (e) {
            console.error(e);
            showToast('⚠️ 移動に失敗しました');
        }
    }

    // =====================================================================
    // 合算
    // =====================================================================
    let mgTickets = [];
    let mgSelectedIds = new Set();

    let mgSelectOrder = []; // 選択した順に id を保持（合疗1/合疗2…の番号付けに使用）

    function resetMergeUI() {
        document.getElementById('mg-table').value = tableNumber || '';
        document.getElementById('mg-tickets-wrap').innerHTML = '';
        document.getElementById('mg-btn-wrap').classList.add('hidden');
        document.getElementById('mg-preview-card').classList.add('hidden');
        document.getElementById('mg-preview').innerHTML = '';
        mgTickets = [];
        mgSelectedIds = new Set();
        mgSelectOrder = [];
    }

    async function searchMergeTickets() {
        const t = document.getElementById('mg-table').value.trim();
        if (!t) { showToast('⚠️ 卓番を入力してください'); return; }
        const wrap = document.getElementById('mg-tickets-wrap');
        wrap.innerHTML = `<div class="empty-note"><i class="fa-solid fa-spinner fa-spin"></i> 検索中...</div>`;
        try {
            const q = window.fbQuery(
                window.fbCollection(window.db, 'orders'),
                window.fbWhere('table', '==', t)
            );
            const snap = await window.fbGetDocs(q);
            mgTickets = [];
            snap.forEach(d => mgTickets.push({ id: d.id, ...d.data() }));
            mgTickets.sort((a, b) => (a.createdAt?.toMillis?.() || 0) - (b.createdAt?.toMillis?.() || 0));
            mgSelectedIds = new Set();
            renderMergeTickets();
        } catch (e) {
            console.error(e);
            wrap.innerHTML = `<div class="empty-note">検索に失敗しました</div>`;
        }
    }

    function renderMergeTickets() {
        const wrap = document.getElementById('mg-tickets-wrap');
        if (mgTickets.length < 2) {
            wrap.innerHTML = mgTickets.length === 0
                ? `<div class="empty-note">この卓の伝票は見つかりませんでした</div>`
                : mgTickets.map(t => ticketCardHtml(t, mgSelectedIds.has(t.id), `toggleMgSelect('${t.id}')`, mgBadgeFor(t.id))).join('') +
                  `<div class="empty-note">合算するには伝票が2枚以上必要です</div>`;
            document.getElementById('mg-btn-wrap').classList.add('hidden');
            document.getElementById('mg-preview-card').classList.add('hidden');
            return;
        }
        wrap.innerHTML = mgTickets.map(t => ticketCardHtml(t, mgSelectedIds.has(t.id), `toggleMgSelect('${t.id}')`, mgBadgeFor(t.id))).join('');
        document.getElementById('mg-btn-wrap').classList.toggle('hidden', mgSelectedIds.size < 2);
        renderMergePreview();
    }

    function mgBadgeFor(id) {
        const idx = mgSelectOrder.indexOf(id);
        if (idx === -1) return '';
        return `<div class="merge-select-badge">合算${idx + 1}</div>`;
    }

    function toggleMgSelect(id) {
        if (mgSelectedIds.has(id)) {
            mgSelectedIds.delete(id);
            mgSelectOrder = mgSelectOrder.filter(x => x !== id);
        } else {
            mgSelectedIds.add(id);
            mgSelectOrder.push(id);
        }
        renderMergeTickets();
    }

    function renderMergePreview() {
        const card = document.getElementById('mg-preview-card');
        const preview = document.getElementById('mg-preview');
        if (mgSelectedIds.size < 2) { card.classList.add('hidden'); preview.innerHTML = ''; return; }
        card.classList.remove('hidden');
        const selected = mgSelectOrder.map(id => mgTickets.find(t => t.id === id)).filter(Boolean);
        let total = 0;
        preview.innerHTML = selected.map((t, i) => {
            const sub = (t.items || []).reduce((s, it) => s + (it.price || 0) * (it.qty || 0), 0);
            total += sub;
            const names = (t.items || []).map(it => `${it.name}×${it.qty}`).join('、');
            return `<div class="mg-preview-row"><span class="mg-num">合算${i + 1}</span><span style="flex:1;min-width:0;">${names || '(商品なし)'}</span><span>${sub}円</span></div>`;
        }).join('');
        preview.innerHTML += `<div class="mg-preview-total">合算後の合計 ${total}円（${selected.length}枚→1枚）</div>`;
    }

    async function executeMerge() {
        if (mgSelectedIds.size < 2) { showToast('⚠️ 合算する伝票を2枚以上選択してください'); return; }
        const selected = mgSelectOrder.map(id => mgTickets.find(t => t.id === id)).filter(Boolean);
        const mergedItems = [];
        selected.forEach(t => { (t.items || []).forEach(it => mergedItems.push(it)); });
        const table = selected[0].table;
        const orderMethod = selected[0].orderMethod || staffCode || 'MERGE';
        const orderLabel = selected.map((t, i) => `合算${i + 1}`).join(' + ');
        if (!confirm(`${table}卓の伝票（${orderLabel}）を合計${selected.length}枚を1枚に合算します。よろしいですか？`)) return;
        try {
            await window.fbAddDoc(
                window.fbCollection(window.db, 'orders'),
                {
                    table: table,
                    status: 'waiting',
                    orderMethod: orderMethod,
                    createdAt: window.fbServerTimestamp(),
                    items: mergedItems
                }
            );
            for (const t of selected) {
                await window.fbDeleteDoc(window.fbDoc(window.db, 'orders', t.id));
            }
            showToast(`✅ ${selected.length}枚の伝票を合算しました`);
            resetMergeUI();
        } catch (e) {
            console.error(e);
            showToast('⚠️ 合算に失敗しました');
        }
    }

    // ---- 伝票カードHTML（テーブル変更・合算共通） ----
    // badgeHtml: 選択順バッジ等を上部に表示するための追加HTML（省略可）
    function ticketCardHtml(t, selected, onClickFn, badgeHtml) {
        const time = t.createdAt?.toDate?.()?.toLocaleTimeString('ja-JP', { hour: '2-digit', minute: '2-digit' }) || '--:--';
        let total = 0;
        const rows = (t.items || []).map(it => {
            total += (it.price || 0) * (it.qty || 0);
            return `${it.name} ×${it.qty}`;
        }).join('、 ');
        return `
        <div class="ticket-card${selected ? ' selected' : ''}" onclick="${onClickFn}">
            ${badgeHtml || ''}
            <div class="ticket-head">
                <span class="tnum"><i class="fa-solid ${selected ? 'fa-square-check' : 'fa-square'}"></i> ${t.table}卓 / ${time}</span>
                <span style="font-size:11px;color:#888;">${t.orderMethod || ''}</span>
            </div>
            <div class="ticket-items">${rows || '(商品なし)'}</div>
            <div class="ticket-total">合計 ${total}円</div>
        </div>`;
    }

    // =====================================================================
    // 従業員登録（使用者コードのマスタ。氏名は登録しない）
    // =====================================================================
    let staffList = []; // { id, code }

    async function registerStaff() {
        const code = document.getElementById('staff-reg-code').value.trim();
        if (!code) { showToast('⚠️ 従業員コードを入力してください'); return; }
        if (staffList.some(s => s.code === code)) { showToast('⚠️ このコードはすでに登録されています'); return; }
        try {
            await window.fbAddDoc(
                window.fbCollection(window.db, 'StaffList'),
                { code, createdAt: window.fbServerTimestamp() }
            );
            document.getElementById('staff-reg-code').value = '';
            showToast(`✅ 従業員コード「${code}」を登録しました`);
            await loadStaffList();
        } catch (e) {
            console.error(e);
            showToast('⚠️ 登録に失敗しました');
        }
    }

    async function loadStaffList() {
        const card = document.getElementById('staff-list-card');
        if (card) card.innerHTML = `<div class="empty-note"><i class="fa-solid fa-spinner fa-spin"></i> 読込中...</div>`;
        try {
            const snap = await window.fbGetDocs(window.fbCollection(window.db, 'StaffList'));
            const list = [];
            snap.forEach(d => list.push({ id: d.id, ...d.data() }));
            list.sort((a, b) => (a.code || '').localeCompare(b.code || ''));
            staffList = list;
            renderStaffCodeSelect();
            if (!card) return;
            if (list.length === 0) {
                card.innerHTML = `<div class="empty-note">まだ従業員コードが登録されていません</div>`;
                return;
            }
            card.innerHTML = list.map(s => `
                <div class="staff-list-row">
                    <div><b>${s.code}</b></div>
                    <button class="allergy-chip-btn" onclick="deleteStaff('${s.id}')"><i class="fa-solid fa-trash"></i></button>
                </div>`).join('');
        } catch (e) {
            console.error(e);
            if (card) card.innerHTML = `<div class="empty-note">読込に失敗しました</div>`;
        }
    }

    // 「注文」画面の使用者コードプリボックス（select）を登録済みコードで再構築
    function renderStaffCodeSelect() {
        const sel = document.getElementById('staff-code-input');
        if (!sel) return;
        const current = staffCode;
        sel.innerHTML = `<option value="">未選択</option>` +
            staffList.map(s => `<option value="${s.code}">${s.code}</option>`).join('');
        // 登録済みのリストに存在する場合のみ引き継ぎ選択を復元
        if (current && staffList.some(s => s.code === current)) {
            sel.value = current;
        } else if (current) {
            // 登録が削除されていた場合は選択をクリア
            staffCode = '';
            localStorage.setItem('staffCode', '');
            updateTableChips();
        }
    }

    async function deleteStaff(id) {
        if (!confirm('この従業員コードを削除しますか？')) return;
        try {
            await window.fbDeleteDoc(window.fbDoc(window.db, 'StaffList', id));
            showToast('🗑 削除しました');
            await loadStaffList();
        } catch (e) {
            console.error(e);
            showToast('⚠️ 削除に失敗しました');
        }
    }

    // =====================================================================
    // アレルギー確認（参照専用）
    // =====================================================================
    function renderAllergyList() {
        const kw = (document.getElementById('allergy-search-input')?.value || '').trim();
        let items = menuList;
        if (kw) items = items.filter(m => m.name.includes(kw) || m.code.includes(kw));
        const card = document.getElementById('allergy-list-card');
        if (items.length === 0) {
            card.innerHTML = `<div class="empty-note">該当する商品がありません</div>`;
            return;
        }
        card.innerHTML = items.map(item => `
            <div class="stock-row">
                <div class="stock-name">${item.icon} ${item.name} <span class="code">#${item.code}</span></div>
                <div style="text-align:right;max-width:55%;">
                    ${item.allergens && item.allergens.length > 0
                        ? item.allergens.map(a => `<span class="allergy-chip-btn on" style="margin:2px;">${a}</span>`).join('')
                        : `<span style="font-size:11px;color:#aaa;">記載なし</span>`}
                </div>
            </div>`).join('');
    }

    // =====================================================================
    // マスタ受信（キャッシュクリア＆アプリ更新）
    // =====================================================================
    async function masterRefresh() {
        if (!confirm('マスタ情報を再受信します。画面が更新されます。よろしいですか？')) return;
        showToast('🔄 マスタ受信中...');
        try {
            if (window.caches && caches.keys) {
                const keys = await caches.keys();
                await Promise.all(keys.map(k => caches.delete(k)));
            }
        } catch (e) {
            console.warn('キャッシュ削除に失敗', e);
        }
        setTimeout(() => {
            location.reload(true);
        }, 300);
    }

    // ---- トースト ----
    let toastTimer;
    function showToast(msg) {
        const toast = document.getElementById('toast');
        toast.textContent = msg;
        toast.classList.add('show');
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => toast.classList.remove('show'), 2200);
    }

    // ---- 初期化 ----
    window.addEventListener('firebase-ready', async () => {
        try {
            await loadMenuFromFirestore();
        } catch (e) {
            console.error('メニューの取得に失敗しました', e);
            showToast('⚠️ メニューの取得に失敗しました。通信環境をご確認ください。');
        }
        try {
            await loadStaffList();
        } catch (e) {
            console.error('従業員コードの取得に失敗しました', e);
        }
        renderCategoryTabs();
        renderMenuGrid();
        document.getElementById('loading-overlay').style.display = 'none';
    });

    showPage('view-home');

    // グローバル公開（インラインonclick用）
    window.selectCategory = selectCategory;
    window.onSearchInput = onSearchInput;
    window.openQtyModal = openQtyModal;
    window.closeQtyModal = closeQtyModal;
    window.changeModalQty = changeModalQty;
    window.confirmAddToCart = confirmAddToCart;
    window.updateCartQty = updateCartQty;
    window.showPage = showPage;
    window.showHomePage = showHomePage;
    window.submitOrder = submitOrder;
    window.showToast = showToast;
    window.onStaffInfoChange = onStaffInfoChange;
    window.renderStockList = renderStockList;
    window.updateStockEditQty = updateStockEditQty;
    window.toggleStockSoldOut = toggleStockSoldOut;
    window.saveAllStock = saveAllStock;
    window.searchTableMoveTickets = searchTableMoveTickets;
    window.toggleTmSelect = toggleTmSelect;
    window.executeTableMove = executeTableMove;
    window.updateTableMovePreview = updateTableMovePreview;
    window.searchMergeTickets = searchMergeTickets;
    window.toggleMgSelect = toggleMgSelect;
    window.executeMerge = executeMerge;
    window.registerStaff = registerStaff;
    window.deleteStaff = deleteStaff;
    window.renderAllergyList = renderAllergyList;
    window.masterRefresh = masterRefresh;
</script>
</body>
</html>
